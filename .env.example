# ══════════════════════════════════════════════════════════════
#  InvoiceFlow — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to version control.
# ══════════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────────
FLASK_ENV=development           # development | production
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Database ───────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL=sqlite:///invoice_app.db
# Production (PostgreSQL on Render/Railway — they set this automatically):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── App / Company Identity ─────────────────────────────────────
APP_NAME=InvoiceFlow
COMPANY_NAME=Your Coaching Class
COMPANY_ADDRESS=123 Main Street, Mumbai, Maharashtra 400001
COMPANY_PHONE=+91 98765 43210
COMPANY_EMAIL=billing@yourcoach.in
COMPANY_GSTIN=27ABCDE1234F1Z5
# Optional: absolute path to a PNG/JPG company logo (shown in PDF header)
COMPANY_LOGO=

# ── Admin Login ────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ── PDF Storage ────────────────────────────────────────────────
# Folder where generated invoice PDFs are saved (relative to project root)
PDF_FOLDER=invoices

# ── UPI Payment QR ────────────────────────────────────────────
# Your UPI VPA — QR will appear on PDF and invoice view page
UPI_ID=yourname@upi
UPI_PAYEE_NAME=Your Coaching Class

# ── Email / SMTP ───────────────────────────────────────────────
# Set MAIL_ENABLED=True to send real emails.
# Development default is False.
MAIL_ENABLED=False

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True

# For Gmail: use an App Password (NOT your account password).
# Create one at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

MAIL_FROM_NAME=InvoiceFlow
MAIL_FROM_ADDRESS=your-email@gmail.com

# If a client has no email, invoice is sent here instead (optional)
MAIL_FALLBACK_RECIPIENT=

# ── APScheduler / Reminders ────────────────────────────────────
# Set SCHEDULER_ENABLED=True in production.
# Development default is False.
SCHEDULER_ENABLED=False

# Time for daily overdue-reminder job (24-hour, server local time)
REMINDER_HOUR=9
REMINDER_MINUTE=0

# IANA timezone — use Asia/Kolkata for IST
SCHEDULER_TIMEZONE=Asia/Kolkata

# Days past due before first reminder fires (0 = reminder on day of expiry)
REMINDER_GRACE_DAYS=0

# Day of month (1–28) for monthly recurring invoice auto-generation
RECURRING_DAY=1

# ── Google OAuth2 ──────────────────────────────────────────────
# Step-by-step setup:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project (or select existing)
#   3. APIs & Services → OAuth consent screen → External → fill required fields
#   4. APIs & Services → Credentials → + Create Credentials → OAuth 2.0 Client ID
#   5. Application type: Web application
#   6. Authorised redirect URIs — add BOTH:
#        http://localhost:5000/auth/google/callback      (development)
#        https://yourdomain.com/auth/google/callback     (production)
#   7. Copy Client ID and Client Secret below

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: comma-separated list of Google emails allowed to log in.
# Leave EMPTY to allow any Google account (useful for personal/single-user deployments).
# Example: GOOGLE_ALLOWED_EMAILS=alice@gmail.com,bob@yourcompany.com
GOOGLE_ALLOWED_EMAILS=
